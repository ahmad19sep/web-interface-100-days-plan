# Copy this file to .env.local for local development (already gitignored).
# In Vercel, add DATABASE_URL under Project Settings → Environment Variables
# instead — or connect Neon via the Vercel Marketplace, which sets it for you.

# Postgres connection string (Neon, or any standard Postgres).
# Get one free at https://neon.tech — create a project, copy the pooled
# connection string, then run db/schema.sql against it once.
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require
